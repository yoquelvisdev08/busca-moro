## Orion - Variables de entorno
## Copia este archivo a .env y ajusta los valores antes de hacer `docker compose up`.

## ----------------------------------------------------------------------------
## PostgreSQL
## ----------------------------------------------------------------------------
POSTGRES_DB=orion
POSTGRES_USER=orion
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://orion:replace_with_strong_password@postgres:5432/orion
DATABASE_URL_SYNC=postgresql://orion:replace_with_strong_password@postgres:5432/orion

## ----------------------------------------------------------------------------
## Redis (broker + result backend + cola directa de Scout/Auditor/Closer/Sniper)
## ----------------------------------------------------------------------------
REDIS_PASSWORD=replace_with_strong_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:replace_with_strong_password@redis:6379/0

## Nombres lógicos de colas (usados por todos los workers)
QUEUE_DISCOVERY=orion:queue:discovery        # Salida del Scout -> entrada del Auditor
QUEUE_AUDIT=orion:queue:audit                # Salida del Auditor -> entrada del Closer
QUEUE_OUTREACH=orion:queue:outreach          # Salida del Closer -> entrega
QUEUE_SNIPER_ALERTS=orion:queue:sniper       # Alertas del Uptime Sniper
QUEUE_DLQ=orion:queue:dlq                    # Dead-letter queue global

## ----------------------------------------------------------------------------
## API (FastAPI)
## ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_SECRET_KEY=replace_with_long_random_string
API_CORS_ORIGINS=http://localhost,http://127.0.0.1

## ----------------------------------------------------------------------------
## LLM provider (cerebro de The Closer) - API OpenAI-compatible
##
## Recomendado: DeepSeek (rapidez + costo bajo + JSON mode).
## Cualquier proveedor compatible con /chat/completions funciona apuntando
## LLM_BASE_URL al endpoint y poniendo el API key correspondiente.
##
## Alternativas:
##   - OpenAI:   LLM_BASE_URL=https://api.openai.com/v1     LLM_MODEL=gpt-4o-mini
##   - Mistral:  LLM_BASE_URL=https://api.mistral.ai/v1     LLM_MODEL=mistral-small
##   - Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1 LLM_MODEL=llama-3.1-70b-versatile
## ----------------------------------------------------------------------------
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace_with_provider_api_key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=900

## ----------------------------------------------------------------------------
## Scout (Go) - Discovery
## ----------------------------------------------------------------------------
SCOUT_CONCURRENCY=16
SCOUT_PORT_SCAN_TIMEOUT_MS=2500ms
SCOUT_HTTP_TIMEOUT_MS=15000ms
SCOUT_LOAD_TIME_THRESHOLD_MS=4000ms
SCOUT_MIN_PROBLEM_SCORE=15
SCOUT_MIN_COMMERCIAL_SCORE=25
SCOUT_DORKS_FILE=/app/config/dorks.txt
SCOUT_TARGETS_FILE=/app/config/seeds.txt
SCOUT_USER_AGENTS_FILE=/app/config/user_agents.txt
SCOUT_PROXIES_FILE=/app/config/proxies.txt
SCOUT_RESPECT_ROBOTS=true
# Intervalo entre pasadas completas del Scout (formato Go: 15m, 1h, 30s).
# 0 = una sola pasada y exit (modo cron externo).
SCOUT_LOOP_INTERVAL=15m

## ----------------------------------------------------------------------------
## Auditor (Playwright + Lighthouse)
## ----------------------------------------------------------------------------
AUDITOR_CONCURRENCY=4
AUDITOR_HEADLESS=true
AUDITOR_SCREENSHOT_DIR=/app/storage/screenshots
AUDITOR_VIEWPORT_WIDTH=1366
AUDITOR_VIEWPORT_HEIGHT=768
AUDITOR_NAV_TIMEOUT_MS=45000
AUDITOR_LIGHTHOUSE_PRESET=desktop
AUDITOR_PROXY_POOL=
AUDITOR_USER_AGENTS_FILE=/app/config/user_agents.txt

## ----------------------------------------------------------------------------
## Closer (Sales Intelligence)
## ----------------------------------------------------------------------------
CLOSER_CONCURRENCY=2
CLOSER_MAX_PAIN_POINTS=3
CLOSER_EMAIL_TONE=consultivo
CLOSER_LANGUAGE=es

## ----------------------------------------------------------------------------
## Outbound Engine (Email / Outreach)
##
## Proveedor de email para envío de cold outreach.
## Opciones: resend, ses, smtp, dev (dev = solo log, no envía)
## ----------------------------------------------------------------------------
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace_with_resend_api_key
EMAIL_FROM=outreach@tudominio.com
EMAIL_FROM_NAME=Tu Nombre
SENDER_PROFILE_WEBSITE=https://tudominio.com
AGENCY_OWNER_NAME=Tu Nombre
AGENCY_WEBSITE=https://tudominio.com
AGENCY_OWNER_TITLE=Desarrollo web y optimización

## ----------------------------------------------------------------------------
## Uptime Sniper
## ----------------------------------------------------------------------------
SNIPER_TARGETS_FILE=/app/config/sniper_targets.txt
SNIPER_INTERVAL_SECONDS=60
SNIPER_FAILURE_THRESHOLD=3
SNIPER_WEBHOOK_URL=

## ----------------------------------------------------------------------------
## Nginx Proxy Manager
## ----------------------------------------------------------------------------
NPM_ADMIN_PORT=81
